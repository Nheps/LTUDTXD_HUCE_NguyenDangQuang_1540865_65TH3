<Window x:Class="LTUDTXD_HUCE_NguyenDangQuang_1540865_65TH3.View.View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Beam Rebar — Cốt thép dầm"
        Width="820" Height="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/materialdesign2.defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/secondary/materialdesigncolor.lime.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- TextBox mặc định -->
            <Style BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}" TargetType="TextBox">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Nút Thêm / Xóa nhỏ -->
            <Style x:Key="SmallBtn" BasedOn="{StaticResource MaterialDesignOutlinedButton}" TargetType="Button">
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,0,6,0" />
            </Style>

            <!-- Nút OK / Cancel -->
            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
                <Setter Property="Margin" Value="6,0,0,0" />
                <Setter Property="Width" Value="90" />
                <Setter Property="Height" Value="32" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Header nhóm thông số -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,10,0,4" />
                <Setter Property="Foreground" Value="#1565C0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="10,8,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"    />   <!-- TabControl -->
                <RowDefinition Height="200"  />   <!-- Sơ đồ nhịp -->
                <RowDefinition Height="Auto" />   <!-- OK / Cancel -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  TABCONTROL — 3 tab                                    -->
            <!-- ══════════════════════════════════════════════════════ -->
            <TabControl Grid.Row="0">

                <!-- ═══ TAB 1: THÉP CHÍNH TRÊN ═════════════════════ -->
                <TabItem Header="  Thép chính trên  ">
                    <Grid Height="385" Margin="6,6,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*"   />
                        </Grid.ColumnDefinitions>

                        <!-- Cột trái -->
                        <GroupBox Grid.Column="0" Margin="0,0,8,0">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Thép trên  " FontWeight="Bold" FontSize="12" />
                                    <TextBlock FontSize="12" Foreground="#1565C0"
                                               Text="{Binding SelectedSpanIndex, StringFormat='(đang cấu hình Nhịp {0})'}" />
                                </StackPanel>
                            </GroupBox.Header>
                            <DockPanel Margin="4,4,4,6">

                                <!-- Nút Thêm / Xóa -->
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Style="{StaticResource SmallBtn}"
                                            Content="+ Thêm lớp"
                                            Command="{Binding AddTopLayerCommand}" />
                                    <Button Style="{StaticResource SmallBtn}"
                                            Content="− Xóa lớp"
                                            Command="{Binding RemoveTopLayerCommand}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#888"
                                               Text="{Binding TopLayers.Count, StringFormat='({0}/5 lớp)'}" />
                                </StackPanel>

                                <!-- DataGrid lớp thép trên -->
                                <DataGrid DockPanel.Dock="Top"
                                          ItemsSource="{Binding TopLayers}"
                                          SelectedItem="{Binding SelectedTopLayer}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeight="50"
                                          Height="200">
                                    <DataGrid.Columns>

                                        <DataGridTemplateColumn Header="Đường kính" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox VerticalAlignment="Center"
                                                              BorderThickness="0"
                                                              Background="Transparent"
                                                              ItemsSource="{Binding DataContext.TypeList,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding BarType, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Name" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Số cây" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox VerticalAlignment="Center"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Neo trên -->
                                <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0">
                                    <TextBlock Text="Chiều dài neo thép trên"
                                               Style="{StaticResource SectionHeader}" />
                                    <TextBox materialDesign:HintAssist.Hint="Neo trên (mm)"
                                             Text="{Binding TopAnchor, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <UIElement />
                            </DockPanel>
                        </GroupBox>

                        <!-- Mặt cắt -->
                        <GroupBox Grid.Column="1">
                            <GroupBox.Header>
                                <TextBlock Text="Mặt cắt ngang" FontWeight="Bold" FontSize="12" Margin="0" />
                            </GroupBox.Header>
                            <Border Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4">
                                <Canvas x:Name="TopPreviewCanvas" Width="280" Height="340" />
                            </Border>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- ═══ TAB 2: THÉP CHÍNH DƯỚI ══════════════════════ -->
                <TabItem Header="  Thép chính dưới  ">
                    <Grid Height="385" Margin="6,6,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*"   />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Margin="0,0,8,0">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Thép dưới  " FontWeight="Bold" FontSize="12" />
                                    <TextBlock FontSize="12" Foreground="#1565C0"
                                               Text="{Binding SelectedSpanIndex, StringFormat='(đang cấu hình Nhịp {0})'}" />
                                </StackPanel>
                            </GroupBox.Header>
                            <DockPanel Margin="4,4,4,6">

                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Style="{StaticResource SmallBtn}"
                                            Content="+ Thêm lớp"
                                            Command="{Binding AddBotLayerCommand}" />
                                    <Button Style="{StaticResource SmallBtn}"
                                            Content="− Xóa lớp"
                                            Command="{Binding RemoveBotLayerCommand}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#888"
                                               Text="{Binding BotLayers.Count, StringFormat='({0}/5 lớp)'}" />
                                </StackPanel>

                                <DataGrid DockPanel.Dock="Top"
                                          ItemsSource="{Binding BotLayers}"
                                          SelectedItem="{Binding SelectedBotLayer}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeight="50"
                                          Height="200">
                                    <DataGrid.Columns>

                                        <DataGridTemplateColumn Header="Đường kính" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox VerticalAlignment="Center"
                                                              BorderThickness="0"
                                                              Background="Transparent"
                                                              ItemsSource="{Binding DataContext.TypeList,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding BarType, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Name" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Số cây" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox VerticalAlignment="Center"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel DockPanel.Dock="Top" Margin="0,14,0,0">
                                    <TextBlock Text="Chiều dài neo thép dưới"
                                               Style="{StaticResource SectionHeader}" />
                                    <TextBox materialDesign:HintAssist.Hint="Neo dưới (mm)"
                                             Text="{Binding BotAnchor, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <UIElement />
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1">
                            <GroupBox.Header>
                                <TextBlock Text="Mặt cắt ngang" FontWeight="Bold" FontSize="12" Margin="0" />
                            </GroupBox.Header>
                            <Border Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4">
                                <Canvas x:Name="BotPreviewCanvas" Width="280" Height="340" />
                            </Border>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- ═══ TAB 3: THÉP ĐAI ══════════════════════════════ -->
                <TabItem Header="  Thép đai  ">
                    <Grid Height="385" Margin="6,6,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*"   />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Margin="0,0,8,0">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Thép đai  " FontWeight="Bold" FontSize="12" />
                                    <TextBlock FontSize="12" Foreground="#1565C0"
                                               Text="{Binding SelectedSpanIndex, StringFormat='(đang cấu hình Nhịp {0})'}" />
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel Margin="8,4,8,8">

                                <TextBlock Text="Đai vùng 2 đầu dầm  (L/4 mỗi đầu)"
                                           Style="{StaticResource SectionHeader}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"   />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                              materialDesign:HintAssist.Hint="Đường kính"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              ItemsSource="{Binding TypeList}"
                                              SelectedItem="{Binding Stirrup}"
                                              DisplayMemberPath="Name" />
                                    <TextBox Grid.Column="1"
                                             materialDesign:HintAssist.Hint="Bước (mm)"
                                             Text="{Binding StirrupSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <TextBlock Text="Đai vùng giữa dầm  (L/2)"
                                           Style="{StaticResource SectionHeader}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"   />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                              materialDesign:HintAssist.Hint="Đường kính"
                                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                              ItemsSource="{Binding TypeList}"
                                              SelectedItem="{Binding StirrupCenter}"
                                              DisplayMemberPath="Name" />
                                    <TextBox Grid.Column="1"
                                             materialDesign:HintAssist.Hint="Bước (mm)"
                                             Text="{Binding StirrupCenterSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Separator Margin="0,16,0,0" />

                                <TextBlock Text="Lớp bảo vệ bê tông"
                                           Style="{StaticResource SectionHeader}" />
                                <TextBox materialDesign:HintAssist.Hint="Chiều dày lớp BV (mm)"
                                         Text="{Binding Cover, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1">
                            <GroupBox.Header>
                                <TextBlock Text="Mặt cắt ngang" FontWeight="Bold" FontSize="12" Margin="0" />
                            </GroupBox.Header>
                            <Border Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="4">
                                <Canvas x:Name="StirrupPreviewCanvas" Width="280" Height="340" />
                            </Border>
                        </GroupBox>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  SƠ ĐỒ NHỊP DẦM                                       -->
            <!-- ══════════════════════════════════════════════════════ -->
            <GroupBox Grid.Row="1" Margin="0,6,0,0">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sơ đồ nhịp dầm" FontWeight="Bold" FontSize="12" Margin="0,0,10,0" />
                        <TextBlock FontSize="12" Foreground="#1565C0"
                                   Text="{Binding SelectedSpanIndex,
                                          StringFormat='— Nhịp {0} đang chọn (click vào nhịp để xem mặt cắt)'}" />
                    </StackPanel>
                </GroupBox.Header>
                <Canvas x:Name="SpanCanvas" Background="White" Margin="4" />
            </GroupBox>

            <!-- OK / Cancel -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="OK"     Command="{Binding OkCommand}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
