<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  View.xaml — Giao diện hộp thoại bố trí cốt thép dầm               ║
    ║                                                                      ║
    ║  Bố cục 2 cột:                                                       ║
    ║    Cột trái (320px): 3 GroupBox nhập thông số thép                   ║
    ║      • Thép chính  — 6 hàng (Top1/2/3, Bot1/2/3)                    ║
    ║      • Thép đai    — 2 hàng (Đai giữa, Đai 2 đầu)                   ║
    ║      • Neo & Lớp BV— 3 hàng (Neo trên, Neo dưới, Lớp bảo vệ)       ║
    ║    Cột phải (300px): Canvas preview mặt cắt + nút OK/Cancel         ║
    ║                                                                      ║
    ║  DataContext: RebarBeamViewModel (gán trong code-behind)             ║
    ║  Tất cả TextBox và ComboBox binding 2 chiều với ViewModel.           ║
    ╚══════════════════════════════════════════════════════════════════════╝
-->
<Window x:Class="LTUDTXD_HUCE_NguyenDangQuang_1540865_65TH3.View.View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LTUDTXD_HUCE_NguyenDangQuang_1540865_65TH3.View"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="BeamRebar — Cốt thép dầm"
        SizeToContent="WidthAndHeight"      
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"               
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.FontSize="13">

    <!-- ================================================================
         RESOURCE DICTIONARY — Style dùng chung toàn cửa sổ
         ================================================================ -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme sáng của MaterialDesign -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <!-- Các giá trị mặc định của MaterialDesign 2 -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/materialdesign2.defaults.xaml" />
                <!-- Màu chủ đạo: xanh dương (Blue) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Blue.xaml" />
                <!-- Màu phụ: xanh lá nhạt (Lime) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/secondary/materialdesigncolor.lime.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Style mặc định cho TextBlock nhãn (label) trong các hàng thông số
                 Width=115 đủ chứa các nhãn dài nhất như "Thép trên lớp 1" -->
            <Style TargetType="TextBlock">
                <Setter Property="Width" Value="115" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="4,0,6,0" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Style mặc định cho ComboBox chọn loại thép (đường kính)
                 Kế thừa MaterialDesignFloatingHintComboBox để có floating label -->
            <Style BasedOn="{StaticResource MaterialDesignFloatingHintComboBox}" TargetType="ComboBox">
                <Setter Property="Width" Value="70" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,8,0" />
            </Style>

            <!-- Style mặc định cho TextBox nhập số lượng/bước đai/chiều dài
                 Kế thừa MaterialDesignFloatingHintTextBox để có floating label -->
            <Style BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}" TargetType="TextBox">
                <Setter Property="Width" Value="90" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- Style mặc định cho Button (OK / Cancel)
                 Kế thừa MaterialDesignRaisedButton để có hiệu ứng nổi -->
            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
                <Setter Property="Margin" Value="5,0,5,0" />
                <Setter Property="Width" Value="90" />
                <Setter Property="Height" Value="32" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="Medium" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Padding ngoài cùng quanh toàn bộ nội dung cửa sổ -->
    <Border Padding="12,10,12,12">

        <!-- Grid gốc: 2 cột — trái (thông số) và phải (preview + nút) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Cột trái: các GroupBox nhập liệu -->
                <ColumnDefinition Width="Auto" /> <!-- Cột phải: canvas + nút bấm -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════
                 CỘT TRÁI — Nhập thông số cốt thép (rộng 320px)
                 ══════════════════════════════════════════════════ -->
            <StackPanel Width="320" Margin="0,0,8,0">

                <!-- ┌─────────────────────────────────────────┐
                     │  NHÓM 1: THÉP CHÍNH (Top1→3, Bot1→3)   │
                     │  Mỗi hàng gồm:                         │
                     │    Col 0 (120px): Nhãn tên lớp thép     │
                     │    Col 1 (80px) : ComboBox chọn D thép  │
                     │    Col 2 (*px)  : TextBox nhập số lượng │
                     └─────────────────────────────────────────┘ -->
                <GroupBox Margin="0,0,0,8">
                    <GroupBox.Header>
                        <TextBlock Margin="0" Width="Auto" FontWeight="Bold" FontSize="13"
                                   Text="Thép chính" />
                    </GroupBox.Header>
                    <Grid Margin="4,4,4,6">
                        <!-- 6 hàng × 50px: Top1, Top2, Top3, Bot1, Bot2, Bot3 -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" /> <!-- Hàng 0: Thép trên lớp 1 -->
                            <RowDefinition Height="50" /> <!-- Hàng 1: Thép trên lớp 2 -->
                            <RowDefinition Height="50" /> <!-- Hàng 2: Thép trên lớp 3 -->
                            <RowDefinition Height="50" /> <!-- Hàng 3: Thép dưới lớp 1 -->
                            <RowDefinition Height="50" /> <!-- Hàng 4: Thép dưới lớp 2 -->
                            <RowDefinition Height="50" /> <!-- Hàng 5: Thép dưới lớp 3 -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" /> <!-- Nhãn -->
                            <ColumnDefinition Width="80" />  <!-- Loại thép (D) -->
                            <ColumnDefinition Width="*" />   <!-- Số lượng -->
                        </Grid.ColumnDefinitions>

                        <!-- Hàng 0: Thép trên lớp 1 — offset 50mm từ mép trên -->
                        <TextBlock Grid.Row="0" Text="Thép trên lớp 1" />
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Top1}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="0" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Top1Count}" />

                        <!-- Hàng 1: Thép trên lớp 2 — offset 130mm từ mép trên -->
                        <TextBlock Grid.Row="1" Text="Thép trên lớp 2" />
                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Top2}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="1" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Top2Count}" />

                        <!-- Hàng 2: Thép trên lớp 3 — offset 210mm từ mép trên -->
                        <TextBlock Grid.Row="2" Text="Thép trên lớp 3" />
                        <ComboBox  Grid.Row="2" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Top3}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="2" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Top3Count}" />

                        <!-- Hàng 3: Thép dưới lớp 1 — offset 50mm từ mép dưới -->
                        <TextBlock Grid.Row="3" Text="Thép dưới lớp 1" />
                        <ComboBox  Grid.Row="3" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Bot1}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="3" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Bot1Count}" />

                        <!-- Hàng 4: Thép dưới lớp 2 — offset 130mm từ mép dưới -->
                        <TextBlock Grid.Row="4" Text="Thép dưới lớp 2" />
                        <ComboBox  Grid.Row="4" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Bot2}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="4" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Bot2Count}" />

                        <!-- Hàng 5: Thép dưới lớp 3 — offset 210mm từ mép dưới -->
                        <TextBlock Grid.Row="5" Text="Thép dưới lớp 3" />
                        <ComboBox  Grid.Row="5" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Bot3}"
                                   DisplayMemberPath="Name" />
                        <TextBox   Grid.Row="5" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Số lượng" Text="{Binding Bot3Count}" />
                    </Grid>
                </GroupBox>

                <!-- ┌─────────────────────────────────────────────┐
                     │  NHÓM 2: THÉP ĐAI                          │
                     │  Mỗi hàng gồm:                             │
                     │    Col 0 (120px): Nhãn vùng đai             │
                     │    Col 1 (80px) : ComboBox chọn D đai       │
                     │    Col 2 (*px)  : TextBox nhập bước đai(mm) │
                     └─────────────────────────────────────────────┘ -->
                <GroupBox Margin="0,0,0,8">
                    <GroupBox.Header>
                        <TextBlock Margin="0" Width="Auto" FontWeight="Bold" FontSize="13"
                                   Text="Thép đai" />
                    </GroupBox.Header>
                    <Grid Margin="4,4,4,6">
                        <!-- 2 hàng: Đai giữa (bước thưa) và Đai 2 đầu (bước dày) -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" /> <!-- Hàng 0: Đai giữa dầm (L/2) -->
                            <RowDefinition Height="50" /> <!-- Hàng 1: Đai 2 đầu dầm (L/4 mỗi đầu) -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Hàng 0: Đai vùng giữa — phân bố trên L/2 giữa dầm -->
                        <TextBlock Grid.Row="0" Text="Đai giữa" />
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding StirrupCenter}"
                                   DisplayMemberPath="Name" />
                        <!-- Bước đai (mm) — binding tới StirrupCenterSpacing, mặc định 200mm -->
                        <TextBox   Grid.Row="0" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Bước đai" Text="{Binding StirrupCenterSpacing}" />

                        <!-- Hàng 1: Đai vùng 2 đầu — phân bố trên L/4 mỗi đầu dầm -->
                        <TextBlock Grid.Row="1" Text="Đai 2 đầu" />
                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="D"
                                   ItemsSource="{Binding TypeList}" SelectedItem="{Binding Stirrup}"
                                   DisplayMemberPath="Name" />
                        <!-- Bước đai (mm) — binding tới StirrupSpacing, mặc định 100mm -->
                        <TextBox   Grid.Row="1" Grid.Column="2"
                                   materialDesign:HintAssist.Hint="Bước đai" Text="{Binding StirrupSpacing}" />
                    </Grid>
                </GroupBox>

                <!-- ┌──────────────────────────────────────────────────┐
                     │  NHÓM 3: THÉP NEO & LỚP BẢO VỆ                  │
                     │  Mỗi hàng gồm:                                  │
                     │    Col 0 (120px): Nhãn                           │
                     │    Col 1 (*px)  : TextBox nhập giá trị (mm)      │
                     └──────────────────────────────────────────────────┘ -->
                <GroupBox Margin="0,0,0,0">
                    <GroupBox.Header>
                        <TextBlock Margin="0" Width="Auto" FontWeight="Bold" FontSize="13"
                                   Text="Thép neo &amp; Lớp bảo vệ" />
                                   <!-- &amp; = ký tự & trong XML -->
                    </GroupBox.Header>
                    <Grid Margin="4,4,4,6">
                        <!-- 3 hàng: Neo trên, Neo dưới, Lớp bảo vệ -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" /> <!-- Hàng 0: Chiều dài neo thép trên (mm) -->
                            <RowDefinition Height="50" /> <!-- Hàng 1: Chiều dài neo thép dưới (mm) -->
                            <RowDefinition Height="50" /> <!-- Hàng 2: Chiều dày lớp bảo vệ (mm) -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Hàng 0: Chiều dài đoạn neo thép trên tại 2 đầu dầm
                             Binding → TopAnchor (mm), mặc định 300mm
                             Thép trên sẽ uốn xuống thêm TopAnchor mm tại 2 đầu -->
                        <TextBlock Grid.Row="0" Text="Neo trên" />
                        <TextBox   Grid.Row="0" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="Chiều dài (mm)" Text="{Binding TopAnchor}" />

                        <!-- Hàng 1: Chiều dài đoạn neo thép dưới tại 2 đầu dầm
                             Binding → BotAnchor (mm), mặc định 300mm
                             Thép dưới sẽ uốn lên thêm BotAnchor mm tại 2 đầu -->
                        <TextBlock Grid.Row="1" Text="Neo dưới" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="Chiều dài (mm)" Text="{Binding BotAnchor}" />

                        <!-- Hàng 2: Chiều dày lớp bảo vệ bê tông
                             Binding → Cover (mm), mặc định 50mm
                             Ảnh hưởng đến: vị trí đai trên canvas và kích thước đai trong Revit -->
                        <TextBlock Grid.Row="2" Text="Lớp BV" />
                        <TextBox   Grid.Row="2" Grid.Column="1"
                                   materialDesign:HintAssist.Hint="Chiều dày (mm)" Text="{Binding Cover}" />
                    </Grid>
                </GroupBox>
            </StackPanel>

            <!-- ══════════════════════════════════════════════════
                 CỘT PHẢI — Preview mặt cắt + Nút bấm (rộng 300px)
                 ══════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Width="300">
                <Grid.RowDefinitions>
                    <RowDefinition />            <!-- Hàng 0: GroupBox preview (chiếm hết không gian còn lại) -->
                    <RowDefinition Height="Auto" /> <!-- Hàng 1: StackPanel chứa nút OK/Cancel -->
                </Grid.RowDefinitions>

                <!-- GroupBox hiển thị mặt cắt ngang dầm dạng preview -->
                <GroupBox>
                    <GroupBox.Header>
                        <TextBlock Margin="0" Width="Auto" FontWeight="Bold" FontSize="13"
                                   Text="Mặt cắt dầm" />
                    </GroupBox.Header>
                    <Border Margin="4"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Background="White">
                        <StackPanel>
                            <TextBlock Text="Mặt cắt ngang" FontWeight="SemiBold" FontSize="11"
                                       Width="Auto" Margin="4,6,0,2" HorizontalAlignment="Left" />
                            <!-- Canvas vẽ preview: ViewModel tìm theo Name="PreviewCanvas"
                                 Kích thước cố định 260×390px.
                                 ViewModel sẽ vẽ: hình chữ nhật dầm + đường viền đai + chấm thép -->
                            <Canvas Name="PreviewCanvas" Width="260" Height="390" />
                        </StackPanel>
                    </Border>
                </GroupBox>

                <!-- Hàng 1: Nút OK và Cancel căn phải
                     OK  → Command=OkCommand  → tạo thép + đóng cửa sổ
                     Cancel → Command=CancelCommand → đóng cửa sổ không tạo thép -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Content="OK"     Command="{Binding OkCommand}" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
